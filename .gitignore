# Local .terraform directory (contains providers and modules)
.terraform/

# Terraform state files (contain sensitive data and infrastructure secrets)
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Exclude all .tfvars files (these often contain your LINODE_TOKEN)
*.tfvars
*.tfvars.json

# Exclude override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Exclude CLI configuration files
.terraformrc
terraform.rc